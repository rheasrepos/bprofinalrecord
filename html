<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The New Golden Record</title>
    <style>
        :root {
            --gold: #D4AF37;
            --space-black: #050505;
            --text-glow: 0 0 10px rgba(212, 175, 55, 0.5);
        }

        body, html {
            margin: 0;
            padding: 0;
            background-color: var(--space-black);
            color: var(--gold);
            font-family: 'Courier New', Courier, monospace; /* Technical/Analog feel */
            height: 100%;
            overflow: hidden;
            background-image: radial-gradient(circle at center, #111 0%, #000 70%);
        }

        /* --- SPLASH SCREEN (The Record Cover) --- */
        #splash-screen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: var(--space-black);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 100;
            transition: opacity 1s ease-in-out;
        }

        .record-cover {
            width: 300px;
            height: 300px;
            border-radius: 50%;
            border: 4px solid var(--gold);
            box-shadow: 0 0 30px var(--text-glow), inset 0 0 20px var(--text-glow);
            position: relative;
            /* Placeholder for actual etchings */
            background: repeating-conic-gradient(
                var(--space-black) 0% 2%,
                var(--gold) 2% 2.2%
            );
            animation: slowSpin 60s linear infinite;
        }

        @keyframes slowSpin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

        #enter-btn {
            margin-top: 40px;
            padding: 15px 30px;
            background: transparent;
            border: 2px solid var(--gold);
            color: var(--gold);
            font-size: 1.2rem;
            cursor: pointer;
            transition: all 0.3s;
        }

        #enter-btn:hover {
            background: var(--gold);
            color: var(--space-black);
            box-shadow: var(--text-glow);
        }

        /* --- MAIN INTERFACE --- */
        #main-content {
            display: none; /* Hidden until entered */
            height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Navigation */
        nav {
            display: flex;
            justify-content: center;
            border-bottom: 1px solid var(--gold);
            padding: 20px;
        }

        .nav-item {
            margin: 0 20px;
            cursor: pointer;
            opacity: 0.6;
            transition: 0.3s;
        }

        .nav-item:hover, .nav-item.active {
            opacity: 1;
            text-shadow: var(--text-glow);
            border-bottom: 2px solid var(--gold);
        }

        /* Content Sections */
        .section-container {
            flex-grow: 1;
            position: relative;
            display: none;
            padding: 40px;
            overflow-y: auto;
        }

        .section-container.active {
            display: flex;
        }

        /* The Drake Looper Interface */
        .looper-interface {
            display: flex;
            flex-wrap: wrap;
            gap: 30px;
            justify-content: center;
            align-items: center;
            width: 100%;
        }

        .control-module {
            border: 1px solid var(--gold);
            padding: 20px;
            width: 200px;
            text-align: center;
            box-shadow: inset 0 0 10px rgba(212, 175, 55, 0.2);
        }

        .knob-label {
            display: block;
            margin-bottom: 15px;
            font-weight: bold;
        }

        /* Custom slider styling */
        input[type=range] {
            -webkit-appearance: none;
            width: 100%;
            background: transparent;
        }
        input[type=range]::-webkit-slider-thumb {
            -webkit-appearance: none;
            height: 20px;
            width: 20px;
            border-radius: 50%;
            background: var(--gold);
            cursor: pointer;
            box-shadow: var(--text-glow);
            margin-top: -8px;
        }
        input[type=range]::-webkit-slider-runnable-track {
            width: 100%;
            height: 4px;
            background: rgba(212, 175, 55, 0.3);
            border: 1px solid var(--gold);
        }

        .visualizer-readout {
            margin-top: 10px;
            font-size: 0.8rem;
            opacity: 0.8;
        }
    </style>
</head>
<body>

    <div id="splash-screen">
        <div class="record-cover">
            </div>
        <h1>THE NEW GOLDEN RECORD</h1>
        <p>[BPRO PROJECT ARCHIVE]</p>
        <button id="enter-btn">ENTER ARCHIVE & INITIALIZE AUDIO</button>
    </div>

    <div id="main-content">
        <nav>
            <div class="nav-item active" data-target="section-universe">UNIVERSE (CONTEXT)</div>
            <div class="nav-item" data-target="section-earth">EARTH (HOME)</div>
            <div class="nav-item" data-target="section-humanity">HUMANITY (MESSAGE)</div>
            <div class="nav-item" data-target="section-looper" style="color:white; border-color:white;">► SIGNAL GENERATOR</div>
        </nav>

        <div id="section-universe" class="section-container active">
            <h2>The Context</h2>
            <p>Placeholder: Scrolling parallax star map, CMB timeline, and fundamental physics constants.</p>
        </div>

        <div id="section-earth" class="section-container">
            <h2>The Home</h2>
            <p>Placeholder: 3D rotating globe showing continental drift. Tree of Life visualization.</p>
        </div>

        <div id="section-humanity" class="section-container">
            <h2>The Message</h2>
            <p>Placeholder: Anthropocene gallery, curated music playlist, greetings map, and open ethical questions.</p>
        </div>

        <div id="section-looper" class="section-container">
            <div style="text-align: center; width: 100%; margin-bottom: 30px;">
                <h2>DRAKE EQUATION SIGNAL GENERATOR</h2>
                <p>Tune the variables to carve civilization out of the cosmic noise.</p>
            </div>
            
            <div class="looper-interface">
                <div class="control-module">
                    <label for="r-star" class="knob-label">R* (Star Density)</label>
                    <input type="range" id="r-star" min="0" max="1" step="0.01" value="0">
                    <div class="visualizer-readout">CMB Noise Level</div>
                </div>

                <div class="control-module">
                    <label for="n-e" class="knob-label">n-e (Habitable Zone)</label>
                    <input type="range" id="n-e" min="100" max="2000" step="10" value="1000">
                    <div class="visualizer-readout">Filter Frequency Check</div>
                </div>

                <div class="control-module" style="border-color: white;">
                    <label for="f-i" class="knob-label">f-i (Intelligence)</label>
                    <input type="range" id="f-i" min="0" max="0.5" step="0.01" value="0">
                    <div class="visualizer-readout">432Hz Harmonic Order</div>
                </div>

                 <div class="control-module">
                    <label for="L-time" class="knob-label">L (Longevity)</label>
                    <input type="range" id="L-time" min="0" max="0.8" step="0.01" value="0">
                    <div class="visualizer-readout">Temporal Echo (Delay)</div>
                </div>
            </div>
            <div style="text-align: center; width: 100%; margin-top: 30px; opacity: 0.7;">
                <p><em>"Base Texture: Brown Noise (CMB) | Intelligence Tuning: 432Hz Sine"</em></p>
            </div>
        </div>
    </div>

    <script>
        // --- NAVIGATION LOGIC ---
        const enterBtn = document.getElementById('enter-btn');
        const splashScreen = document.getElementById('splash-screen');
        const mainContent = document.getElementById('main-content');
        const navItems = document.querySelectorAll('.nav-item');
        const sections = document.querySelectorAll('.section-container');

        enterBtn.addEventListener('click', () => {
            splashScreen.style.opacity = '0';
            setTimeout(() => {
                splashScreen.style.display = 'none';
                mainContent.style.display = 'flex';
                // Initialize Audio on user gesture
                initAudio();
            }, 1000);
        });

        navItems.forEach(item => {
            item.addEventListener('click', () => {
                navItems.forEach(i => i.classList.remove('active'));
                sections.forEach(s => s.classList.remove('active'));
                item.classList.add('active');
                const targetId = item.getAttribute('data-target');
                document.getElementById(targetId).classList.add('active');
            });
        });

        // --- WEB AUDIO DRAKE LOOPER ---
        let audioCtx;
        let noiseNode, noiseGain;
        let oscNode, oscGain;
        let filterNode;
        let delayNode, delayFeedback, delayGain;

        function initAudio() {
            audioCtx = new (window.AudioContext || window.webkitAudioContext)();

            // Master Volume
            const masterGain = audioCtx.createGain();
            masterGain.gain.value = 0.5;
            masterGain.connect(audioCtx.destination);

            // --- LAYER 1: THE CMB (Brown Noise) ---
            // Create buffer for noise
            const bufferSize = 2 * audioCtx.sampleRate;
            const noiseBuffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
            const output = noiseBuffer.getChannelData(0);
            let lastOut = 0.0;
            for (let i = 0; i < bufferSize; i++) {
                // Brown noise generation (smoother than white noise)
                const white = Math.random() * 2 - 1;
                output[i] = (lastOut + (0.02 * white)) / 1.02;
                lastOut = output[i];
                output[i] *= 3.5; // boost
            }
            
            noiseNode = audioCtx.createBufferSource();
            noiseNode.buffer = noiseBuffer;
            noiseNode.loop = true;
            noiseNode.start(0);

            // Filter for the noise (Habitable Zone n-e)
            filterNode = audioCtx.createBiquadFilter();
            filterNode.type = "bandpass";
            filterNode.frequency.value = 1000; // Starting center freq
            filterNode.Q.value = 1; // Width of the band

            // Gain for the noise (Star Rate R*)
            noiseGain = audioCtx.createGain();
            noiseGain.gain.value = 0; // Start silent

            // Connect Noise Chain: Noise -> Filter -> Gain -> Master
            noiseNode.connect(filterNode);
            filterNode.connect(noiseGain);
            noiseGain.connect(masterGain);


            // --- LAYER 2: INTELLIGENCE (432Hz Tone) ---
            oscNode = audioCtx.createOscillator();
            oscNode.type = 'sine';
            oscNode.frequency.setValueAtTime(432, audioCtx.currentTime); // THE GOLDEN PITCH
            oscNode.start(0);

            // Gain for the Oscillator (Intelligence f-i)
            oscGain = audioCtx.createGain();
            oscGain.gain.value = 0; // Start silent

            // Connect Tone Chain: Osc -> Gain -> Master
            oscNode.connect(oscGain);
            oscGain.connect(masterGain);

            // --- LAYER 3: LONGEVITY (Delay Effect L) ---
            delayNode = audioCtx.createDelay();
            delayNode.delayTime.value = 0.5; // 500ms echo

            delayFeedback = audioCtx.createGain();
            delayFeedback.gain.value = 0.0; // Start with no echo persistence

            // Route master output into delay, and delay back into itself
            masterGain.connect(delayNode);
            delayNode.connect(delayFeedback);
            delayFeedback.connect(delayNode);
            // Connect delay output to destination
            delayNode.connect(audioCtx.destination);


            // --- WIRE UP THE SLIDERS ---
            // R* Star Density -> Noise Volume
            document.getElementById('r-star').addEventListener('input', (e) => {
                noiseGain.gain.setTargetAtTime(parseFloat(e.target.value), audioCtx.currentTime, 0.02);
            });

            // n-e Habitable Zone -> Filter Frequency
            document.getElementById('n-e').addEventListener('input', (e) => {
                 filterNode.frequency.setTargetAtTime(parseFloat(e.target.value), audioCtx.currentTime, 0.1);
            });

            // f-i Intelligence -> 432Hz Volume
            document.getElementById('f-i').addEventListener('input', (e) => {
                oscGain.gain.setTargetAtTime(parseFloat(e.target.value), audioCtx.currentTime, 0.02);
            });

             // L Longevity -> Delay Feedback amount
             document.getElementById('L-time').addEventListener('input', (e) => {
                delayFeedback.gain.setTargetAtTime(parseFloat(e.target.value), audioCtx.currentTime, 0.02);
            });

        }

    </script>
</body>
</html>